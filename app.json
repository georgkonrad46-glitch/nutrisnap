{
  "expo": {
    "name": "NutriSnap - Kalorienzähler",
    "slug": "nutrisnap",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/icon.png",
    "userInterfaceStyle": "dark",
    "splash": {
      "image": "./assets/splash.png",
      "resizeMode": "contain",
      "backgroundColor": "#0D1825"
    },
    "assetBundlePatterns": ["**/*"],
    "ios": {
      "supportsTablet": false,
      "bundleIdentifier": "com.gkonrad.nutrisnap",
      "buildNumber": "1",
      "infoPlist": {
        "NSCameraUsageDescription": "NutriSnap benötigt Kamerazugriff zum Scannen von Barcodes und Fotografieren von Mahlzeiten für die KI-Nährwertanalyse.",
        "NSPhotoLibraryUsageDescription": "NutriSnap benötigt Zugriff auf deine Fotos zum Analysieren von Mahlzeiten.",
        "CFBundleDevelopmentRegion": "de"
      }
    },
    "android": {
      "adaptiveIcon": {
        "foregroundImage": "./assets/adaptive-icon.png",
        "backgroundColor": "#0D1825"
      },
      "package": "com.gkonrad.nutrisnap",
      "versionCode": 1,
      "permissions": [
        "CAMERA",
        "READ_EXTERNAL_STORAGE",
        "WRITE_EXTERNAL_STORAGE"
      ]
    },
    "locales": {
      "de": "./locales/de.json"
    },
    "extra": {
      "eas": {
        "projectId": "58c4fb16-d5f8-46bf-b175-673311ee2f00"
      }
    },
    "plugins": [
      [
        "./plugins/withKotlinVersion",
        {
          "version": "2.0.21"
        }
      ],
      "./plugins/withBundleCompressionFix",
      [
        "expo-camera",
        {
          "cameraPermission": "NutriSnap benoetigt Kamerazugriff zum Scannen von Barcodes und Fotografieren von Mahlzeiten."
        }
      ],
      [
        "expo-image-picker",
        {
          "photosPermission": "NutriSnap benoetigt Zugriff auf deine Fotos zum Analysieren von Mahlzeiten."
        }
      ]
    ]
  }
}
